    {
        "id": "n_gate_hombro",
        "type": "function",
        "z": "g6_flow",
        "name": "Gate modo (hombro)",
        "func": "// Deja pasar el mensaje solo si su origen coincide con el modo\n// actual: en modo Automatico solo pasan los mensajes calculados\n// desde el sensor (origen \"auto\"); en modo Manual solo pasan los que\n// vienen del slider (origen \"manual\"). Asi el slider y el calculo\n// automatico nunca compiten por mandarle un angulo distinto al servo\n// al mismo tiempo.\nvar modoAutomatico = flow.get('modo_automatico') || false;\nvar dejarPasar = modoAutomatico ? (msg.origen === 'auto') : (msg.origen === 'manual');\nreturn dejarPasar ? msg : null;",
        "outputs": 1,
