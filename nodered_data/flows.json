    {
        "id": "n_store_estado",
        "type": "function",
        "z": "g6_flow",
        "name": "Guardar estado sensores",
        "func": "// Este nodo recibe los mensajes ya parseados (JSON) de los 3 sensores\n// del brazo (hombro, codo, muneca). msg.topic trae el topico MQTT\n// completo, por ejemplo: g6/brazo/sensores/hombro\n//\n// De ahi se extrae solo el nombre de la articulacion (la ultima parte\n// del topico, despues de la ultima \"/\") para usarla como llave dentro\n// del estado guardado.\nvar partes = msg.topic.split('/');\nvar articulacion = partes[partes.length - 1]; // \"hombro\" | \"codo\" | \"muneca\"\n\n// \"estado_sensores\" vive en el contexto del flow. Como settings.js tiene\n// contextStorage con modulo \"localfilesystem\", Node-RED escribe este\n// contexto a disco (dentro de nodered_data/context) cada 30 segundos.\n// Esto cumple el requisito de \"almacenar el estado actual de los\n// sensores\" sin necesitar una base de datos aparte.\n//\n// IMPORTANTE: esto NO guarda un historial de movimientos, guarda solo\n// la ULTIMA lectura de cada articulacion (se sobreescribe cada vez).\n// Cada mensaje MQTT que llega dispara este guardado, sin importar si\n// el valor cambio o no respecto al anterior -- no hay logica de\n// \"solo guardar si la posicion cambio\", se guarda siempre que llega\n// un mensaje nuevo.\nvar estado = flow.get('estado_sensores') || {};\nestado[articulacion] = {\n    valores: msg.payload,\n    ultima_actualizacion: new Date().toISOString()\n};\nflow.set('estado_sensores', estado);\n\n// No se reenvia el mensaje a ningun otro nodo: este nodo es solo\n// para persistir el estado. La visualizacion en tiempo real la hace\n// el ui_template conectado directamente a cada nodo \"mqtt in\".\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 460,
        "y": 340,
        "wires": [
            []
        ]
    },
    {
        "id": "n_tpl_hombro",
        "type": "ui_template",
        "z": "g6_flow",
        "group": "g6_group_row2",
        "name": "Hombro (tiempo real)",
        "order": 1,
        "width": 4,
        "height": 4,
        "format": "<style>\n  .g6-card{padding:6px 8px}\n  .g6-title{margin:0 0 6px;font-size:15px;font-weight:700;color:#1f2328}\n  .g6-accent{height:3px;border-radius:2px;margin-bottom:12px;background:#2563EB}\n  .g6-sub{font-size:11px;letter-spacing:.04em;text-transform:uppercase;color:#8a8f98;margin:0 0 8px}\n  .g6-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px 8px}\n  .g6-cell{text-align:center}\n  .g6-label{display:block;font-size:10px;color:#9aa0a6;letter-spacing:.03em}\n  .g6-value{display:block;font-variant-numeric:tabular-nums;font-size:15px;font-weight:600;color:#1f2328}\n  .g6-divider{height:1px;background:#eef0f2;margin:10px 0}\n</style>\n<div class='g6-card'>\n  <p class='g6-title'>Hombro</p>\n  <div class='g6-accent'></div>\n  <p class='g6-sub'>Acelerómetro (LSB)</p>\n  <div class='g6-grid'>\n    <div class='g6-cell'><span class='g6-label'>AX</span><span class='g6-value'>{{msg.payload.ax}}</span></div>\n    <div class='g6-cell'><span class='g6-label'>AY</span><span class='g6-value'>{{msg.payload.ay}}</span></div>\n    <div class='g6-cell'><span class='g6-label'>AZ</span><span class='g6-value'>{{msg.payload.az}}</span></div>\n  </div>\n  <div class='g6-divider'></div>\n  <p class='g6-sub'>Giroscopio (LSB)</p>\n  <div class='g6-grid'>\n    <div class='g6-cell'><span class='g6-label'>GX</span><span class='g6-value'>{{msg.payload.gx}}</span></div>\n    <div class='g6-cell'><span class='g6-label'>GY</span><span class='g6-value'>{{msg.payload.gy}}</span></div>\n    <div class='g6-cell'><span class='g6-label'>GZ</span><span class='g6-value'>{{msg.payload.gz}}</span></div>\n  </div>\n</div>",
        "storeOutMessages": true,
        "fwdInMessages": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 440,
        "y": 100,
        "wires": [
            []
        ]
    },
