        "format": "<style>\n  .g6-card{padding:6px 8px}\n  .g6-title{margin:0 0 6px;font-size:15px;font-weight:700;color:#1f2328}\n  .g6-accent{height:3px;border-radius:2px;margin-bottom:12px;background:#D97706}\n  .g6-sub{font-size:11px;letter-spacing:.04em;text-transform:uppercase;color:#8a8f98;margin:0 0 8px}\n  .g6-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px 8px}\n  .g6-cell{text-align:center}\n  .g6-label{display:block;font-size:10px;color:#9aa0a6;letter-spacing:.03em}\n  .g6-value{display:block;font-variant-numeric:tabular-nums;font-size:15px;font-weight:600;color:#1f2328}\n  .g6-divider{height:1px;background:#eef0f2;margin:10px 0}\n</style>\n<div class='g6-card'>\n  <p class='g6-title'>Muñeca</p>\n  <div class='g6-accent'></div>\n  <p class='g6-sub'>Acelerómetro (LSB)</p>\n  <div class='g6-grid'>\n    <div class='g6-cell'><span class='g6-label'>AX</span><span class='g6-value'>{{msg.payload.ax}}</span></div>\n    <div class='g6-cell'><span class='g6-label'>AY</span><span class='g6-value'>{{msg.payload.ay}}</span></div>\n    <div class='g6-cell'><span class='g6-label'>AZ</span><span class='g6-value'>{{msg.payload.az}}</span></div>\n  </div>\n  <div class='g6-divider'></div>\n  <p class='g6-sub'>Giroscopio (LSB)</p>\n  <div class='g6-grid'>\n    <div class='g6-cell'><span class='g6-label'>GX</span><span class='g6-value'>{{msg.payload.gx}}</span></div>\n    <div class='g6-cell'><span class='g6-label'>GY</span><span class='g6-value'>{{msg.payload.gy}}</span></div>\n    <div class='g6-cell'><span class='g6-label'>GZ</span><span class='g6-value'>{{msg.payload.gz}}</span></div>\n  </div>\n</div>",
