    {
        "id": "n_calc_hombro_angulo",
        "type": "function",
        "z": "g6_flow",
        "name": "Calcular ángulo hombro",
        "func": "// Calcula el angulo del servo del hombro a partir del acelerometro\n// crudo del sensor de hombro (eje AY -- fue el eje que en la\n// calibracion real mostro el barrido mas limpio entre \"abajo\" y\n// \"arriba\", sin necesitar atan2).\n//\n// Calibracion real (2026-07-14), promediando muestras con el brazo\n// quieto en cada pose:\n//   AY = +15916  -> brazo pegado al cuerpo, abajo      -> servo 0 grados\n//   AY = -12363  -> brazo estirado completamente arriba -> servo 180 grados\n//\n// Tambien se guarda este AY crudo en el contexto del flow: el calculo\n// del codo (nodo n_calc_codo_angulo) lo necesita para restar el\n// movimiento del hombro y aislar la flexion real del codo.\nvar AY_ABAJO = 15916;\nvar AY_ARRIBA = -12363;\n\nvar ay = msg.payload.ay;\nflow.set('ultimo_hombro_ay', ay);\n\nvar angulo = (ay - AY_ABAJO) / (AY_ARRIBA - AY_ABAJO) * 180;\nangulo = Math.max(0, Math.min(180, angulo)); // recorte de seguridad, nunca sale de 0-180\n\nmsg.payload = String(Math.round(angulo));\nmsg.topic = \"g6/brazo/hombro/angulo/cmd\";\nmsg.origen = \"auto\";\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 480,
        "y": 100,
        "wires": [
            [
                "n_gate_hombro"
            ]
        ]
    },
    {
        "id": "n_calc_codo_angulo",
        "type": "function",
        "z": "g6_flow",
        "name": "Calcular ángulo codo",
        "func": "// Calcula el angulo del servo del codo, pero NO desde el AY crudo del\n// codo solo -- usa la DIFERENCIA entre el AY del codo y el ultimo AY\n// del hombro (guardado por n_calc_hombro_angulo).\n//\n// Por que: el sensor del codo mide inclinacion absoluta respecto a la\n// gravedad, no el angulo real de la articulacion. Si subes el hombro\n// con el codo recto, el AY del codo cambia casi igual que el del\n// hombro, aunque el codo no se haya flexionado nada (esto se\n// confirmo con datos reales durante la calibracion). Restando el AY\n// del hombro se cancela ese movimiento compartido y queda solo la\n// flexion real del codo.\n//\n// Calibracion real (2026-07-14):\n//   diferencia ~ +709   -> codo recto (promedio de +434 y +984,\n//                          medido con el hombro abajo y arriba)\n//   diferencia = -27207 -> codo flexionado al maximo\nvar DIFF_RECTO = 709;\nvar DIFF_FLEXIONADO = -27207;\n\nvar ultimoHombroAy = flow.get('ultimo_hombro_ay');\nif (ultimoHombroAy === undefined) {\n    // Todavia no llego ninguna lectura del hombro -- no se puede\n    // calcular la diferencia todavia, se ignora este mensaje.\n    return null;\n}\n\nvar codoAy = msg.payload.ay;\nvar diferencia = codoAy - ultimoHombroAy;\n\nvar angulo = (diferencia - DIFF_RECTO) / (DIFF_FLEXIONADO - DIFF_RECTO) * 180;\nangulo = Math.max(0, Math.min(180, angulo));\n\nmsg.payload = String(Math.round(angulo));\nmsg.topic = \"g6/brazo/codo/angulo/cmd\";\nmsg.origen = \"auto\";\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 480,
        "y": 180,
        "wires": [
            [
                "n_gate_codo"
            ]
        ]
    },
