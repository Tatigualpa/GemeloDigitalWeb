    {
        "id": "n_guardar_modo",
        "type": "function",
        "z": "g6_flow",
        "name": "Guardar modo",
        "func": "// Guarda el modo actual (true = Automatico, false = Manual) en el\n// contexto del flow. Los nodos \"gate\" de cada servo (n_gate_hombro,\n// n_gate_codo) leen esta misma variable para decidir si dejan pasar\n// el valor del slider manual o el valor calculado desde el sensor.\n//\n// Si nadie toco el switch todavia, flow.get devuelve undefined, y los\n// gates lo tratan como \"false\" (Manual) -- arranca en modo manual por\n// seguridad, no mueve los servos solo por sensores sin que alguien lo\n// active a proposito.\nflow.set('modo_automatico', msg.payload === true);\nreturn null;",
        "outputs": 0,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 470,
        "y": 560,
        "wires": []
