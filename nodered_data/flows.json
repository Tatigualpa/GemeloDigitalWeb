        "format": "<style>\n  .g6-badgewrap{display:flex;flex-direction:column;justify-content:center;height:100%;padding:6px 4px}\n  .g6-badgecaption{font-size:10px;letter-spacing:.04em;text-transform:uppercase;color:#9aa0a6;margin:0 0 6px}\n  .g6-badge{display:inline-flex;align-items:center;gap:8px;padding:6px 14px;border-radius:999px;font-weight:600;font-size:13px;width:fit-content}\n  .g6-dot{width:8px;height:8px;border-radius:50%;flex:none}\n</style>\n<div class='g6-badgewrap'>\n  <p class='g6-badgecaption'>Estado confirmado</p>\n  <span class='g6-badge' ng-style=\"{background: msg.payload=='ON' ? '#DCFCE7' : '#F1F5F9', color: msg.payload=='ON' ? '#15803D' : '#64748B'}\">\n    <span class='g6-dot' ng-style=\"{background: msg.payload=='ON' ? '#22C55E' : '#94A3B8'}\"></span>\n    {{msg.payload || 'Sin confirmar'}}\n  </span>\n</div>",
